{
  "manifest_version": 3,
  "name": "Attendance Widget Pro",
  "version": "1.1",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "http://localhost:5173/*",
    "https://meet.google.com/*",
    "http://your-api-domain.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:5173/*", "https://meet.google.com/*"],
      "js": ["content.js"]
    }
  ]
}