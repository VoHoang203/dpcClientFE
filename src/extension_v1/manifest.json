{
  "manifest_version": 3,
  "name": "Hệ Thống Điểm Danh Đảng Viên",
  "description": "Tự động điểm danh Đảng viên v2",
  "version": "2.0",
  "permissions": ["storage", "tabs", "alarms", "webNavigation"],
  "host_permissions": [
    "http://localhost:5173/*",
    "http://localhost:3000/*",
    "http://localhost:8080/*",
    "https://meet.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "http://localhost:3000/*",
        "https://meet.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "assets/icon48.jpg",
    "128": "assets/icon48.jpg"
  }
}
